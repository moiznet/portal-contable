# Variables de entorno — DESARROLLO LOCAL
# Copia este archivo como .env y ajusta los valores
# NUNCA commitear el .env con valores reales

# Base de datos (Docker local)
DATABASE_URL=postgresql://daem_user:daem_pass@localhost:5432/daem_prueba

# JWT
# ATENCION: en produccion este valor viene de AWS Secrets Manager (arn:aws:secretsmanager:eu-west-1:...)
# Para desarrollo local puedes usar cualquier string largo y aleatorio
JWT_SECRET=supersecret_dev_only

# Puerto del servidor
PORT=3000

# Entorno
NODE_ENV=development

# Feature flags (no implementados todavia)
# FEATURE_AUDIT_LOG=false
# FEATURE_RATE_LIMITING=false
# FEATURE_REFRESH_TOKENS=false

# Integracion con servicios externos (no activos en desarrollo)
# SENDGRID_API_KEY=
# SENTRY_DSN=
# DATADOG_API_KEY=
